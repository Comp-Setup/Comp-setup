<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Діагностика: Здоров'я диска (S.M.A.R.T.)</title>
    <hta:application id="oHTA" applicationname="SmartCheck" border="thin" caption="yes" showintaskbar="yes" singleinstance="yes" sysmenu="yes" windowstate="normal" scroll="yes">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f0f0; padding: 20px; text-align: center; }
        .card { background: white; border-radius: 8px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: auto; }
        button { background: #00a4ef; color: white; border: none; padding: 12px 25px; cursor: pointer; border-radius: 4px; font-size: 16px; font-weight: bold; }
        button:hover { background: #0078d4; }
        #output { margin-top: 25px; text-align: left; background: #1e1e1e; color: #fff; padding: 20px; border-radius: 8px; font-size: 15px; display: none; }
    </style>
    <script>
        function checkDisk() {
            var out = document.getElementById("output"); out.style.display = "block"; out.innerHTML = "Перевірка дисків...";
            try {
                var shell = new ActiveXObject("WScript.Shell");
                var cmd = "powershell -NoProfile -Command \"Get-WmiObject -Class MSStorageDriver_FailurePredictStatus -Namespace root\\wmi | ForEach-Object { $name = $_.InstanceName; $status = $_.PredictFailure; Write-Output ($name + '|' + $status) }\"";
                var exec = shell.Exec(cmd);
                var res = exec.StdOut.ReadAll().replace(/\r/g, "");
                if(!res || res.trim() === "") { out.innerHTML = "<span style='color:#fd7e14'>Не вдалося отримати прямий доступ до контролера диска. Потрібен запуск від імені Адміністратора.</span>"; return; }
                
                var lines = res.split('\n'); var html = "";
                for(var i=0; i<lines.length; i++) {
                    if(lines[i].trim() !== "") {
                        var parts = lines[i].split('|');
                        var name = parts[0].split('\\')[0]; // Берем только понятное имя
                        var isFailing = parts[1].trim() === "True";
                        
                        html += "<div style='margin-bottom:10px;'><b>Диск:</b> " + name + "<br>";
                        if(isFailing) html += "<span style='color:#dc3545; font-weight:bold;'>🔴 КРИТИЧНО! Диск виходить з ладу. Терміново збережіть дані та замініть накопичувач!</span></div>";
                        else html += "<span style='color:#28a745;'>🟢 Відмінно. Апаратних помилок S.M.A.R.T. не виявлено.</span></div>";
                    }
                }
                out.innerHTML = html;
            } catch(e) { out.innerHTML = "<span style='color:red'>Помилка: " + e.message + "</span>"; }
        }
    </script>
</head>
<body>
<div class="card">
    <h2>Перевірка здоров'я диска</h2>
    <p>Апаратний тест накопичувача на наявність прихованих пошкоджень.</p>
    <button onclick="checkDisk()">Запустити S.M.A.R.T. Тест</button>
    <div id="output"></div>
</div>
</body>
</html>