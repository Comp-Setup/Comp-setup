<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Діагностика: Ліцензія Windows</title>
    <hta:application id="oHTA" applicationname="KeyCheck" border="thin" caption="yes" showintaskbar="yes" singleinstance="yes" sysmenu="yes" windowstate="normal" scroll="yes">
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f0f0; padding: 20px; text-align: center; }
        .card { background: white; border-radius: 8px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); max-width: 600px; margin: auto; }
        button { background: #fd7e14; color: white; border: none; padding: 12px 25px; cursor: pointer; border-radius: 4px; font-size: 16px; font-weight: bold; }
        button:hover { background: #e36a0b; }
        #output { margin-top: 25px; text-align: center; background: #1e1e1e; color: #fff; padding: 20px; border-radius: 8px; font-size: 18px; display: none; }
        .key-text { color: #00ff00; font-family: monospace; font-size: 22px; font-weight: bold; letter-spacing: 2px; margin: 15px 0; padding: 10px; border: 1px dashed #555; display: inline-block;}
    </style>
    <script>
        function checkKey() {
            var out = document.getElementById("output"); out.style.display = "block"; out.innerHTML = "Пошук ключа в BIOS/UEFI...";
            try {
                var shell = new ActiveXObject("WScript.Shell");
                var cmd = "powershell -NoProfile -Command \"(Get-WmiObject -query 'select * from SoftwareLicensingService').OA3xOriginalProductKey\"";
                var exec = shell.Exec(cmd);
                var key = exec.StdOut.ReadAll().replace(/\r/g, "").trim();
                
                if(key && key !== "") {
                    out.innerHTML = "<div style='color:#ccc; font-size:14px;'>Заводський ліцензійний ключ знайдено:</div><div class='key-text'>" + key + "</div><div style='color:#28a745; font-size:14px;'>Зробіть фото цього екрану! Ми використаємо цей ключ для легальної активації нової Windows.</div>";
                } else {
                    out.innerHTML = "<span style='color:#fd7e14; font-size:15px;'>Заводський ключ у BIOS не знайдено.<br><br>Це нормально, якщо у вас старий ПК або ліцензія прив'язана до вашого цифрового акаунту Microsoft.</span>";
                }
            } catch(e) { out.innerHTML = "<span style='color:red; font-size:14px;'>Помилка доступу: Запустіть від імені Адміністратора.</span>"; }
        }
    </script>
</head>
<body>
<div class="card">
    <h2>Пошук ключа Windows</h2>
    <p>Витягує ліцензійний ключ, вшитий виробником у материнську плату.</p>
    <button onclick="checkKey()">Показати мій ключ</button>
    <div id="output"></div>
</div>
</body>
</html>